# Coda Engine V7.2 - Environment Configuration Template
# Copy this file to .env and fill in your keys.

# --- SurrealDB Configuration ---
SURREALDB_URL=ws://127.0.0.1:11001/rpc
SURREALDB_NAMESPACE=ai_agents_v2
SURREALDB_DATABASE=agent_system
SURREALDB_USER=root
SURREALDB_PASS=AgentSecurePass2026

# --- LLM Configuration ---
# Options: gemini-1.5-flash, gemini-1.5-pro, claude-3-5-sonnet-20240620, etc.
# 默认主模型
DEFAULT_MODEL_NAME=gemini-1.5-flash
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

OLLAMA_MODEL_NAME=qwen3.5:2b
OLLAMA_BASE_URL=http://localhost:11434/v1
#ollama,google,anthropic,glm,gpt
# 智能三级调度：IDE 免费额度 -> API Key -> 本地 Ollama  
LLM_PRIORITY_CHAIN=ide,google,ollama

# --- Connectivity ---
GEMINI_PROXY=http://127.0.0.1:7888
LOG_LEVEL=INFO

# --- Agent Identity ---
Coda_AGENT=Coda_V7_Core

# ── V7.1: OAuth Constants ──
ANTIGRAVITY_CLIENT_ID=1071006060591-tmhssin2h21lcre235vtolojh4g403ep.apps.googleusercontent.com
ANTIGRAVITY_CLIENT_SECRET=YOUR_ANTIGRAVITY_CLIENT_SECRET
CLIENT_ID=681255809395-oo8ft2oprdrnp9e3aqf6av3hmdib135j.apps.googleusercontent.com
CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Wiki 知识库扫描路径 (多路径用英文分号 ; 分隔)
# 留空则默认扫描 agents/ 目录
# 示例: WIKI_SCAN_PATHS=D:\ai\workspace\agents;D:\notes;C:\projects\docs;C:\Users\James\.agents;C:\Users\James\.gemini\antigravity\brain
WIKI_SCAN_PATHS=D:\ai\workspace\agents

# Wiki 联邦挂载 (只读订阅上游知识库, 搜索时自动合并)
# 格式: atlas.db 绝对路径, 英文分号分隔
# 层级由路径关键字自动推断: corp/enterprise=L0, dept/team=L1, 其余=L2
# 示例 (多层联邦):
#   WIKI_MOUNTS=D:\company\corp-wiki\_meta\atlas.db;D:\company\dept-eng\_meta\atlas.db
# 当前: 暂无上游挂载 (留空 = 仅本地检索)
WIKI_MOUNTS=

# Skill 技能扫描路径 (多路径用英文分号 ; 分隔)
# 留空则默认扫描 skills/ 目录C:\Users\James\.agents\skills;
SKILL_SCAN_PATHS=d:\ai\workspace\skills;D:\ai\docs\huashu-design
